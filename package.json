{
  "name": "blockfinax-server",
  "version": "2.0.0",
  "description": "Production-ready WebSocket server for BlockFinax real-time messaging and calling",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:watch": "nodemon --watch src src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "echo \"No linter configured\"",
    "prod": "NODE_ENV=production node src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop blockfinax-server",
    "pm2:restart": "pm2 restart blockfinax-server",
    "pm2:logs": "pm2 logs blockfinax-server"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "socket.io": "^4.7.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "websocket",
    "socket.io",
    "blockchain",
    "messaging",
    "webrtc",
    "real-time",
    "production",
    "scalable"
  ],
  "author": "BlockFinax Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlockFinax-v2/server.git"
  },
  "bugs": {
    "url": "https://github.com/BlockFinax-v2/server/issues"
  },
  "homepage": "https://github.com/BlockFinax-v2/server#readme"
}